{
  "name": "@xgen-sandbox/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for xgen-sandbox",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "@msgpack/msgpack": "^3.0.0-beta2"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
