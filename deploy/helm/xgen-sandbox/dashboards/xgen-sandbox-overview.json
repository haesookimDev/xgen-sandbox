{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 45 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "xgen_sandboxes_active", "legendFormat": "Active" }
      ],
      "title": "Active Sandboxes",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "xgen_sandbox_create_total", "legendFormat": "Created" }
      ],
      "title": "Total Created",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(xgen_warm_pool_available)", "legendFormat": "Available" }
      ],
      "title": "Warm Pool Available",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(xgen_http_requests_total{status=~\"5..\"}[$__rate_interval])) / sum(rate(xgen_http_requests_total[$__rate_interval])) * 100",
          "legendFormat": "Error Rate %"
        }
      ],
      "title": "Error Rate",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "HTTP Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(xgen_http_requests_total[$__rate_interval]))", "legendFormat": "Total" },
        { "expr": "sum(rate(xgen_http_requests_total{status=~\"2..\"}[$__rate_interval]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(xgen_http_requests_total{status=~\"4..\"}[$__rate_interval]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(xgen_http_requests_total{status=~\"5..\"}[$__rate_interval]))", "legendFormat": "5xx" }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(xgen_http_request_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(xgen_http_request_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(xgen_http_request_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P99" }
      ],
      "title": "Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "pieType": "donut" },
      "targets": [
        { "expr": "sum by (status) (increase(xgen_http_requests_total[$__rate_interval]))", "legendFormat": "{{status}}" }
      ],
      "title": "Status Code Distribution",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Sandbox Lifecycle",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "xgen_sandboxes_by_template", "legendFormat": "{{template}}" }
      ],
      "title": "Active Sandboxes by Template",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 22,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(xgen_sandbox_create_total[$__rate_interval])", "legendFormat": "Create" },
        { "expr": "rate(xgen_sandbox_delete_total[$__rate_interval])", "legendFormat": "Delete" }
      ],
      "title": "Create / Delete Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 23,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(xgen_sandbox_pod_create_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(xgen_sandbox_pod_create_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(xgen_sandbox_pod_create_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "P99" }
      ],
      "title": "Pod Create Duration",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "Warm Pool",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 31,
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "targets": [
        { "expr": "xgen_warm_pool_available", "legendFormat": "Available - {{template}}" },
        { "expr": "xgen_warm_pool_target", "legendFormat": "Target - {{template}}" }
      ],
      "title": "Warm Pool: Available vs Target",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 32,
      "targets": [
        { "expr": "rate(xgen_warm_pool_claims_total[$__rate_interval])", "legendFormat": "Claims/s" }
      ],
      "title": "Warm Pool Claim Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 33,
      "targets": [
        { "expr": "rate(xgen_warm_pool_replenish_failures_total[$__rate_interval])", "legendFormat": "Failures/s" }
      ],
      "title": "Warm Pool Replenish Failures",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "Auth & WebSocket",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 41,
      "targets": [
        { "expr": "rate(xgen_auth_token_generated_total[$__rate_interval])", "legendFormat": "Tokens/s" }
      ],
      "title": "Token Generation Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 42,
      "targets": [
        { "expr": "sum by (reason) (rate(xgen_auth_failures_total[$__rate_interval]))", "legendFormat": "{{reason}}" }
      ],
      "title": "Auth Failures by Reason",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "id": 43,
      "targets": [
        { "expr": "xgen_ws_connections_active", "legendFormat": "Active WS" }
      ],
      "title": "Active WebSocket Connections",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["xgen-sandbox", "kubernetes"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s",
        "current": { "selected": false, "text": "auto", "value": "$__auto_interval_interval" },
        "hide": 0,
        "label": "Interval",
        "name": "interval",
        "options": [
          { "selected": true, "text": "auto", "value": "$__auto_interval_interval" },
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": false, "text": "5m", "value": "5m" },
          { "selected": false, "text": "15m", "value": "15m" }
        ],
        "query": "1m,5m,15m",
        "type": "interval"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "xgen-sandbox Overview",
  "uid": "xgen-sandbox-overview",
  "version": 1
}
